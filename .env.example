TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Base URL for Hero SMS API provider
# HERO_BASE_URL=https://hero-sms.com

# SMS-Activate compatible endpoint from the official OpenAPI file
# HERO_REQUEST_PATH=/stubs/handler_api.php

# API key from Hero SMS panel
# HERO_API_KEY=your_hero_api_key

# Action for requesting a number
# HERO_ACTION_GET_NUMBER=getNumber
# HERO_ACTION_GET_PRICES=getPrices
# HERO_ACTION_GET_STATUS=getStatus
# HERO_ACTION_GET_ACTIVE_ACTIVATIONS=getActiveActivations

# Optional request timeout
# HERO_TIMEOUT_MS=15000
# OTP_POLL_INTERVAL_MS=5000

# Set 1 to show "Copy Number / Copy OTP" buttons on auto OTP notifications
# ENABLE_COPY_BUTTONS=0

# Telegram menu defaults
# MENU_SERVICE=wa
# MENU_SERVICE_FALLBACKS=
# ALLOWED_MENU_SERVICES=wa
# MENU_COUNTRY_PHILIPPINES=4
# MENU_COUNTRY_LABEL=Philippines +63
